APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./data/app.db
AUTH_MODE=local
# Web sign-in always uses real email delivery. Configure these values through
# CONFIGURE_VOUCH.bat; preview mode is reserved for automated tests.
LOCAL_OTP_DELIVERY=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
OTP_MIN_INTERVAL_SECONDS=60
OTP_HOURLY_LIMIT=5
# Non-loopback deployments require Supabase with a public/publishable key, never service-role.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
AUTH_SESSION_HOURS=168
DATA_DIR=./data
DRAFTS_DIR=./drafts
LOGS_DIR=./logs
CONFIG_DIR=./config
ADMIN_PASSWORD=
SECRET_KEY=
MOCK_MODE=true

X_AUTH_MODE=oauth1
# Manual publication requires Read and write app permissions. Regenerate the
# OAuth 1.0a Access Token and Secret after changing permissions in X Console.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_USER_ID=
X_OAUTH2_SCOPES="tweet.read tweet.write users.read offline.access media.write"
# Private X Activity events such as post.mention.create require X_AUTH_MODE=oauth2.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

XAI_API_KEY=
XAI_MODEL=grok-4.5

# Provider enablement and selection live in config/runtime.yml.
ALLOW_MODEL_FALLBACK=false

HEYGEN_MODE=disabled
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Rotate any token previously pasted into chat before using it here.
TELEGRAM_BOT_TOKEN=

# Optional authenticated HTTP(S) proxy. Supported compact forms:
# host:port:username:password or username:password:host:port
OUTBOUND_PROXY_ENABLED=false
OUTBOUND_PROXY=

PUBLISH_ENABLED=false
AUTO_PUBLISH=false
STORE_LLM_PAYLOADS=false
LOG_LEVEL=INFO
COLOR_LOGS=true

# Local UTC-day safety budget; separate from the X Console Manage Spend Cap.
DAILY_X_READ_LIMIT_USD=0.25
DAILY_X_WRITE_LIMIT_USD=
X_WRITE_BUDGET_MATCH_READ=false
DAILY_OPENAI_LIMIT_USD=
DAILY_XAI_LIMIT_USD=
DAILY_HEYGEN_LIMIT_USD=

# Cost estimates are configured only in config/cost_estimates.yml.
# `null` means unknown; write 0 only when an explicit zero estimate is intended.
